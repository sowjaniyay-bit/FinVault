# FinVault Environment Variables
# Copy this to .env and fill in your values

# JWT Secret (change this to a random string in production)
SECRET_KEY=finvault_super_secret_2024

# Admin Key
ADMIN_KEY=finvault_admin_2024

# Google Gemini API Key — used for Scan Bill (Vision) feature
# Get free at https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# Plaid Credentials (get from https://dashboard.plaid.com)
# For sandbox testing use: sandbox.plaid.com
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_sandbox_secret
PLAID_ENV=sandbox
